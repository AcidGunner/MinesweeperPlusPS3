        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>global.sweepers_data=0;
_index=0;
_total="??";
anim=0;
lines=0;
data=0;

directory_create(working_directory+"msplus_sweepers");

for (var i=0; i&lt;500; i++)
{
    title[i]="";
    desc[i]="";
    uploader[i]="";
    creator[i]="";
    sweeper[i]=0;
}

url="http://acidps3.22web.org/games/ps3/msplus/sweepers/";
http_get(url+"database.txt");

</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="2" enumb="1">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if _index &gt;= _total
{
    audio_loop_sound(mus_vs_lobby,177444,882825,44100,0);
    exit;
}

var line = lines[| _index];

if(string_length(string_length(line)) &gt; 0)
{
    var entry = json_decode(line);
    show_debug_message(ds_map_find_value(entry, "title"));

    title[_index]=ds_map_find_value(entry, "title");
    desc[_index]=ds_map_find_value(entry, "description");
    uploader[_index]=ds_map_find_value(entry, "uploader");
    creator[_index]=ds_map_find_value(entry, "sheetcreator");
    
    var _png = string(ds_map_find_value(entry, "file"));
    http_get_file(url+"uploads/"+_png,working_directory+"msplus_sweepers/"+_png);
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="2" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>lines = string_split(global.sweepers_data, chr(10));
data = json_decode(string(global.sweepers_data));

_total = ds_list_size(lines)-1;

alarm[1]=1;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="7" enumb="62">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>var result = ds_map_find_value(async_load, "result");

if global.sweepers_data==0
{
    show_debug_message(result);
    global.sweepers_data = result;
    _total=0;
    _index=0;
    alarm[0]=5;
}
else
{
    sweeper[_index]=sprite_add(result,1,0,0,0,0);
    _index++;
    alarm[1]=5;
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_halign(fa_center);
draw_set_valign(fa_middle);
draw_set_font(fnt_main);
draw_set_color(c_white);
if !(_index &gt;= _total) draw_text(320,240,"Workshop loading...#"+string(_index)+"/"+string(_total)+" LOADED")
else
{
    anim+=0.04;
    anim = anim mod 2;
    
    draw_sprite_tiled_ext(spr_bg4,anim,0,0,2,2,c_white,1);
    
    for (var i = 0; i &lt; _total; i++)
    {
        var _t = 0;
        if floor(anim)==1 _t = 40;
        draw_sprite_part_ext(sweeper[i],0,_t,0,40,40,50-20,50+(i*90)-20,2,2,c_white,1);
        
        draw_set_halign(fa_left);
        draw_set_font(fnt_main);
        draw_set_valign(fa_top);
        draw_text(120,40+(i*90)-5,title[i]);
        var _t = string_width(title[i]);
        
        draw_set_font(fnt_smol);
        draw_text(_t+125,30+(i*90),"Uploaded by:#"+uploader[i]+"#Created by:#"+creator[i]);
        draw_text_ext(120,70+(i*90),desc[i],-1,_t);
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
