        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Switch music Test

var t_menu_music = 12+menu_music;
var p_menu_music = 12+prev_music;
var _snd = 0;
if instance_exists(obj_audio_loop_sound)
{
    _snd = audio_sound_get_track_position(obj_audio_loop_sound._audio);
    instance_destroy(obj_audio_loop_sound);
};
audio_stop_sound(global._music[p_menu_music]);
audio_loop_sound(global._music[t_menu_music],global._st[13],global._en[13],44100,0);
if _snd!=0 audio_sound_set_track_position(obj_audio_loop_sound._audio,_snd);
prev_music = menu_music;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if select=0
{
    if obj_input.a
    {
        select=1;
        if global.stage&gt;1
        {
            var _question = show_question("Would you like to start a new game?")
            if !_question
            {
                start_game();
                exit;
            }
        }
        type=1;
        obj_menu_adventure.alarm[1]=5;
    }
    if obj_input.c
    {
        select=1;
        type=2;
        obj_menu_freeplay.alarm[1]=5;
    }
    if obj_input.select
    {
        select=1;
        audio_stop_all();
        audio_play_sound(sfx_test,0,false);
        save_game();
        alarm[2]=60;
    }
    if obj_input.bl
    {
        if !gamepad_is_connected(1)
        {
            show_message(global.str[61]);
            exit;
        }
        select=1;
        global.menu_t=menu_music;
        global.m_g_t=menu_music;
        audio_stop_all();
        audio_play_sound(sfx_game_start,0,false);
        save_game();
        alarm[1]=60;
    }
}

switch type
{
    case 0: temp_x=0; break;
    case 1: temp_x=-320; break;
    case 2: temp_x=320; break;
}
x=lerp(x,temp_x,0.1);
</string>
          </argument>
        </arguments>
      </action>
