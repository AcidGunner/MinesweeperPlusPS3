    <event eventtype="2" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Switch music Test

var t_menu_music = 12+menu_music;
var p_menu_music = 12+prev_music;
var _snd = 0;
if instance_exists(obj_audio_loop_sound)
{
    _snd = audio_sound_get_track_position(obj_audio_loop_sound._audio);
    instance_destroy(obj_audio_loop_sound);
};
for (var i=13; i&lt;24; i++)
{
    audio_stop_sound(global._music[i]);
}
init_globals_mus();
audio_loop_sound(global._music[t_menu_music],global._st[13],global._en[13],44100,0);
if _snd!=0 audio_sound_set_track_position(obj_audio_loop_sound._audio,_snd);
prev_music = menu_music;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if select = 0
{
    if obj_input.rig selected--;
    if obj_input.lef selected++;
}

rot -= angle_difference(rot, selected*(360/image_number))/(0.2*room_speed);
item = -selected mod image_number;
if item&lt;0 item+=image_number;

if obj_input.a &amp;&amp; select=0
{
    select=1;
    if item=0
    {
        if global.stage&gt;1
        {
            var _question = show_question(global.str[100])
            if !_question
            {
                start_game();
                exit;
            }
        }
        type=1;
        global.stage=1;
        ini_open("msplus-ps3-save.ini");
        ini_write_string("save","current_time","");
        ini_close();
        if instance_exists(obj_chap1_data) instance_destroy(obj_chap1_data);
        obj_menu_adventure.alarm[1]=5;
    }
    else if item=1
    {
        type=2;
        obj_menu_freeplay.alarm[1]=5;
    }
    else if item=2
    {
        type=4;
        obj_menu_challenges.alarm[1]=5;
    }
    else if item=3
    {
        type=3;
        obj_menu_loadout.alarm[1]=5;
    }
}

/*
if obj_input.select &amp;&amp; select=0
{
    select=1;
    audio_stop_all();
    audio_play_sound(sfx_test,0,false);
    save_game();
    alarm[2]=60;
    alarm[3]=45;
}*/

if select=1 menu_y=lerp(menu_y,360,0.1)
else menu_y=lerp(menu_y,120,0.1);
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_colour(c_white);
draw_set_valign(fa_center);
draw_set_halign(fa_middle);
draw_set_font(fnt_smoler);
var pr, i;
i = 0;
pr = ds_priority_create();
repeat image_number
{
    ds_priority_add(pr,i,lengthdir_y(1,(rot-90)+i*(360/image_number)))
    i+=1;
}
repeat image_number
{
    i=ds_priority_delete_min(pr);
    
    var alpha = 0;
    if i!=item alpha = 0.25;
    
    var _xx = menu_x+lengthdir_x(menu_width/2,(rot-90)+i*(360/image_number));
    draw_sprite_ext(sprite_index,i,_xx,menu_y,0.24,0.24,0,c_white,alpha);
}
ds_priority_destroy(pr);

var _x = menu_x+lengthdir_x(menu_width/2,(rot-90)+item*(360/image_number));
draw_sprite_ext(sprite_index,item,_x,menu_y,0.25,0.25,0,c_white,1);

draw_set_colour(c_black);
draw_set_alpha(0.5);

switch item
{
    case 0:
    {
        draw_rectangle(_x-56,menu_y-10-29,_x+55,menu_y+10-29,false);
        draw_rectangle(_x-56,menu_y-10+29,_x+55,menu_y+10+29,false);
        draw_set_colour(c_white);
        draw_set_alpha(1);
        draw_text_outline(_x,menu_y-29,global.str[42],c_white,c_black,1);
        draw_text_outline(_x,menu_y+29,global.str[43],c_white,c_black,1);
        break;
    }
    case 1:
    {
        draw_rectangle(_x-56,menu_y-10,_x+55,menu_y+10,false);
        draw_set_colour(c_white);
        draw_set_alpha(1);
        draw_text_outline(_x,menu_y,global.str[41],c_white,c_black,1);
        break;
    }
    case 2:
    {
        draw_rectangle(_x-56,menu_y-10,_x+55,menu_y+10,false);
        draw_set_colour(c_white);
        draw_set_alpha(1);
        draw_text_outline(_x,menu_y,"Challenges",c_white,c_black,1);
        break;
    }
    case 3:
    {
        draw_rectangle(_x-56,menu_y-10,_x+55,menu_y+10,false);
        draw_set_colour(c_white);
        draw_set_alpha(1);
        draw_text_outline(_x,menu_y,"Loadout",c_white,c_black,1);
        break;
    }
}
draw_set_colour(c_white);
draw_set_alpha(1);

draw_text_outline(160-90,menu_y,"&lt;",c_white,c_black,1);
draw_text_outline(160+90,menu_y,"&gt;",c_white,c_black,1);
draw_text_outline(160,menu_y+90,"[X]",c_white,c_black,1);
</string>
          </argument>
        </arguments>
      </action>
    </event>
