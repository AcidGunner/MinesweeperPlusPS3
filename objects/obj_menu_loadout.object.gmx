        <arguments>
          <argument>
            <kind>1</kind>
            <string>global.stage=0;
room_goto(rm_game);
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if select=0
{
    if obj_input.l1 &amp;&amp; global.smiley_face&gt;0 global.smiley_face--;
    if obj_input.r1 &amp;&amp; global.smiley_face&lt;8 global.smiley_face++;
    if obj_input.l2 &amp;&amp; global.hat_type&gt;0 global.hat_type--;
    if obj_input.r2 &amp;&amp; global.hat_type&lt;8 global.hat_type++;
    if obj_input.bl
    {
        select=1;
        obj_main_menu.type=0;
        obj_main_menu.select=0;
    }
}

if select=1 &amp;&amp; obj_main_menu.type!=3 temp_x=-320 else temp_x=0;
x=lerp(x,temp_x,0.1);

temp+=0.05;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_font(fnt_smoler);
draw_set_valign(fa_top);
draw_set_halign(fa_middle);
draw_text_outline(x+160,y+70,"[L1/R1] "+global.str[89],c_white,c_black,1);
draw_text_outline(x+160,y+90,"[L2/R2] "+global.str[88],c_white,c_black,1);
draw_sprite_stretched(spr_ui3,0,x+136,20,48,48);

switch global.smiley_face
{
    case 0: sprite = spr_smiley_1; temp1=0; break;
    case 1: sprite = spr_smiley_2; temp1=0; break;
    case 2: sprite = spr_smiley_3; temp1=1; break;
    case 3: sprite = spr_smiley_4; temp1=0; break;
    case 4: sprite = spr_smiley_5; temp1=2; break;
    case 5: sprite = spr_smiley_6; temp1=0; break;
    case 6: sprite = spr_smiley_86; temp1=0; break;
    case 7: sprite = spr_smiley_7; temp1=0; break;
    case 8: sprite = spr_smiley_8; temp1=0; break;
}

switch global.hat_type
{
    case 0: hat = -1; break;
    case 1: hat = spr_hat1; break;
    case 2: hat = spr_hat2; break;
    case 3: hat = spr_hat3; break;
    case 4: hat = spr_hat4; break;
    case 5: hat = spr_hat5; break;
    case 6: hat = spr_hat6; break;
    case 7: hat = spr_hat7; break;
    case 8: hat = spr_hat8; break;
    default: hat = -1; break;
}

if temp1==0 draw_sprite(sprite,0,x+160,44+the_y)
else if temp1==1 draw_sprite(sprite,0+(temp mod 2),x+160,44+the_y)
else draw_sprite(sprite,0+(temp mod 3),x+160,44+the_y);

if hat!=-1
{
    draw_sprite(hat,0,x+160,44);
    if global.hat_type==6 or global.hat_type==7 the_y=1 else the_y=2;
}
else the_y=1;

draw_set_valign(fa_bottom);
draw_text_outline(x+160,230,"[○] - "+global.str[13],c_white,c_black,1);

</string>
          </argument>
        </arguments>
      </action>
    </event>
