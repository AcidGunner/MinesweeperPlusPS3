        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>select=1;
temp_x=x;
sprite=0;
hat=0;
the_y=0;
temp=0;
temp1=0;

grid_w=9;
grid_h=9;
grid_m=10;

spr_smiley_1=spr_smiley1;
spr_smiley_2=spr_smiley2;
spr_smiley_3=spr_smiley3;
spr_smiley_4=spr_smiley4;
spr_smiley_5=spr_smiley5;
spr_smiley_6=spr_smiley6;
spr_smiley_7=spr_smiley7;
spr_smiley_8=spr_smiley_alien;
spr_smiley_86=spr_smiley86;

if global.route=1
{
    spr_smiley_1=spr_murasa1;
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="2" enumb="1">
