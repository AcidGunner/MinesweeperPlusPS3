    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>image_anim+=image_anim_speed;
image_anim3+=image_anim_speed;

image_anim2+=image_anim_speed/2;
image_anim2 = image_anim2 mod 2;
image_anim3 = image_anim3 mod 3;

if global.stage == 9 &amp;&amp; cutscene == false &amp;&amp; obj_game.win == false
    image_anim = image_anim mod 3;
else
    image_anim = image_anim mod 2;

var temp1 = (room_width/2);
var mousex=obj_input.mx;
var mousey=obj_input.my;

if obj_game.win == false
{
    if cutscene == false
    {
        if cutscene_10_lost
        {
            cutscene_10_lose+=image_anim_speed/2;
            if cutscene_10_lose&gt;=3 cutscene_10_lose=3;
            sprite_index=spr_smiley_6;
            if cutscene_10_lose&lt;1 image_index = 8
            else image_index = 13+cutscene_10_lose;
            exit;
        }
        if instance_exists(obj_9_end) &amp;&amp; obj_9_end.go_on=1
        {
            if sprite_index==spr_smiley_3 image_index=26+image_anim2
            else if sprite_index==spr_smiley_5 image_index=27+image_anim2
            else if sprite_index==spr_smiley_6 image_index=17+image_anim2
            else if sprite_index==spr_smiley_bonus
            {
                sprite_index=spr_smiley_5;
                image_index=27+image_anim2;
            }
            else image_index=14+image_anim2;
            exit;
        }
        if instance_exists(obj_audio_pitcher) &amp;&amp; obj_audio_pitcher.go_on=1
        {
            if sprite_index==spr_smiley_3 image_index=26+image_anim
            else if sprite_index==spr_smiley_5 image_index=27+image_anim
            else if sprite_index==spr_smiley_6 image_index=17+image_anim
            else image_index=14+image_anim;
            exit;
        }
        if obj_game.lost
        {
            if sprite_index==spr_smiley_3 image_index = 16+image_anim2
            else if sprite_index==spr_smiley_5 image_index = 26
            else image_index = 8;
            
            if global.route==1 &amp;&amp; instance_exists(obj_9)
            {
                sprite_index=spr_smiley_bonus;
                image_index = 5;
            }
            exit;
        }
        if mine_detected = 1
        {
            if sprite_index==spr_smiley_3 image_index = temp3+image_anim2
            else if sprite_index==spr_smiley_5 image_index = temp3+image_anim
            else image_index = temp3;
            exit;
        }
        else if mine_detected = 2
        {
            if sprite_index==spr_smiley_3 image_index = 24+image_anim2
            else if sprite_index==spr_smiley_5 image_index = 24+image_anim2
            else image_index = 12+image_anim2;
            exit;
        }
        
        switch global.stage
        {
            case 86: sprite_index = spr_smiley_86; break;
            case 9: sprite_index = spr_smiley_5; break;
            case 10: sprite_index = spr_smiley_6; break;
            case 910: sprite_index = spr_smiley_5; break;
            case 11: sprite_index = spr_smiley_7; break;
            default: switch global.smiley_face
            {
                case 0: sprite_index = spr_smiley_1; break;
                case 1: sprite_index = spr_smiley_2; break;
