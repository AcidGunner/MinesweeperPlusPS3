    {
        global.menu_t=obj_main_menu.menu_music;
        select=1;
        audio_stop_all();
        audio_play_sound(sfx_game_start,0,false);
        setup_field(difficulty);
        save_game();
        alarm[0]=60;
    }
    if obj_input.bl
    {
        select=1;
        obj_main_menu.type=0;
        obj_main_menu.select=0;
    }
    if obj_input.upp &amp;&amp; difficulty&gt;0 difficulty--;
    if obj_input.dow &amp;&amp; difficulty&lt;3 difficulty++;
}

if select=1 &amp;&amp; obj_main_menu.type!=1 temp_x=320 else temp_x=0;
x=lerp(x,temp_x,0.1);
</string>
