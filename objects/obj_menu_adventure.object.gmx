            <string>if select=0
{
    if obj_input.a
    {
        select=1;
        global.stage=1;
        start_game();
    }
    if obj_input.select
    {
        select=1;
        type=1;
        obj_menu_adventure_settings.select=0;
    }
    if obj_input.bl
    {
        select=1;
        obj_main_menu.type=0;
        obj_main_menu.select=0;
    }
    if obj_input.upp &amp;&amp; global.difficulty&gt;0 global.difficulty--;
    if obj_input.dow &amp;&amp; global.difficulty&lt;3 global.difficulty++;
}

if select=1 &amp;&amp; obj_main_menu.type!=1 temp_x=320 else temp_x=0;
if select=1 &amp;&amp; type!=0 temp_y=240; else temp_y=0;
x=lerp(x,temp_x,0.1);
y=lerp(y,temp_y,0.1);
</string>
