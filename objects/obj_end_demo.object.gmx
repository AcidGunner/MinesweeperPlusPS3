{
    y1=lerp(y1,-2,0.1);
    y2=lerp(y2,242,0.1);
}
image+=0.08;
draw_sprite_stretched(sprite,image,0,0,320,240);
draw_set_color(c_black);
draw_rectangle(0,-10,320,y1,false);
draw_rectangle(0,250,320,y2,false);
draw_set_valign(fa_center);
draw_set_halign(fa_middle);
draw_set_font(fnt_main);
draw_text_outline(160,y1-30,global.str[0],c_red,c_white,1);
draw_set_font(fnt_smol);
draw_text_outline(275,y1-10,"PS3 "+global.str[1],c_red,c_white,1);
draw_text_outline(160,y2+30,global.str[68],c_red,c_white,1);

if thanks=1
{
    draw_text_outline(160,210,global.str[69]+"#"+global.str[2],c_red,c_white,1);
    if obj_input.start &amp;&amp; !pressed
