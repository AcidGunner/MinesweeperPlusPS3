        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Time system re-work!
time[1]=0;
time[2]=0;
time[3]=0;
time[4]=0;
time[5]=0;
time[6]=0;
time[7]=0;
time[8]=0;
time[9]=0;
time[10]=0;
time[11]=0;
time[12]=0; //12 soon
time[13]=0; //nan
time_str="";

time_limit=8+global.episode;

ini_open("msplus-ps3-save.ini");
if ini_key_exists("save","current_time")
{
    temp0 = ini_read_string("save","current_time","")
    if temp0!=""
    {   
        time_split(temp0,"_");
        show_debug_message("data is probably loaded.");
    }
}
ini_close();

alarm[0]=1;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="2" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>time_str="";

for (var i = 1; i &lt;= time_limit; i++)
{
    time_str+=string(time[i])+"_";
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
