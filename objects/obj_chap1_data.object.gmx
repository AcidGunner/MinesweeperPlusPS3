        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if !(obj_input.l2h &amp;&amp; global.debug) exit;

draw_set_valign(fa_top);
draw_set_halign(fa_left);
draw_set_font(fnt_smol);
draw_set_colour(c_white);
draw_text_outline(0,0,time_str,c_white,c_black,1);
</string>
          </argument>
        </arguments>
      </action>
    </event>
