        <arguments>
          <argument>
            <kind>1</kind>
            <string>var g_o_x = obj_game.grid_offset_x;
var g_o_y = obj_game.grid_offset_y;
var off_x = obj_game.off_x;
var off_y = obj_game.off_y;
var zoom = obj_game.zoom;
var draw_size = obj_game.cell_size * zoom;
var d_s = draw_size;
var h_s = (draw_size*0.5);
var x_s = boss_x * d_s;
var y_s = boss_y * d_s;

_part1=lerp(_part1,_part2,0.1);
zap=lerp(zap,zop,0.1);

x = g_o_x + x_s + h_s;
base_y = g_o_y + y_s + h_s;

if !float
{
    x+=irandom_range(zoom*3,-zoom*3);
    base_y+=irandom_range(zoom*3,-zoom*3);
}
</string>
          </argument>
        </arguments>
      </action>
