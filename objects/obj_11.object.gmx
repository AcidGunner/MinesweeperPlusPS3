        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Auto-flag remaining mines

if won=1
{
    for (var fx = 0; fx &lt; obj_game.grid_w; fx++)
    for (var fy = 0; fy &lt; obj_game.grid_h; fy++)
    {
        if (obj_game.grid_type[# fx, fy] &gt; 0)
            obj_game.flagged[# fx, fy] = true;
    }
    mines_left = 0;
    obj_game.win=true;
    if global.stage==9 audio_play_sound(global.stage9_win,0,false)
    else if global.stage==10 audio_play_sound(global.stage10_win,0,false)
    else if global.stage==11 audio_play_sound(global.stage11_win,0,false)
    else with obj_game you_won_sfx();
    instance_destroy();
}
else instance_create(0,0,obj_9_end);
</string>
          </argument>
        </arguments>
      </action>
    </event>
