            <string>obj_game.lost=1;
obj_smiley.cutscene=false;
if global.stage==9
{
    obj_smiley.sprite_index=spr_smiley5;
}
else if global.stage==10
{
    obj_smiley.cutscene_10_lost=true;
}
go=-1;
alarm[2]=5;
if global.stage!=0
{
    alarm[3]=5*global.FSP-20;
    alarm[4]=5*global.FSP;
}
else
{
    obj_ui.alarm[5]=4*global.FSP-20;
    obj_ui.alarm[6]=4*global.FSP;
}
</string>
