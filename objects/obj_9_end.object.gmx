        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_color(c_white);
draw_set_alpha(alpha);
draw_rectangle(-50,-50,370,370,false);

if go=1 alpha=lerp(alpha,1,0.2)
else if go=-1 &amp;&amp; alpha&gt;0 alpha-=0.005;

if !show exit;

_u+=0.01;
var u1 = sin(_u);
var u2 = sin(_u+2);

draw_set_font(fnt_main);
draw_set_halign(fa_middle);
draw_set_valign(fa_center);
if selected=0
{
    draw_text_outline(160,70,global.str[94],c_white,c_black,1);
    draw_set_font(fnt_smol);
    draw_text_outline(160,120+u1,"X - "+global.str[95],c_blue,c_black,1);
    draw_text_outline(160,144+u2,"O - "+global.str[96],c_red,c_black,1);
}
else
{
    if go_on=1 draw_text_outline(160,70,global.str[97],c_white,c_black,1)
    else draw_text_outline(160,70,global.str[98],c_white,c_black,1)
}
</string>
          </argument>
        </arguments>
      </action>
