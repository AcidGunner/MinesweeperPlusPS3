        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if selected=0
{
    if obj_input.a
    {
        selected=1;
        audio_stop_all();
        go_on=1;
        lives=3;
        audio_play_sound(sfx_1up,0,false);
        alarm[6]=3.4*global.FSP;
        alarm[8]=(3.4*global.FSP)-15;
    }
    if obj_input.b
    {
        selected=1;
        audio_stop_all();
        lost=1;
        audio_play_sound(sfx_gameover,0,false);
        alarm[7]=3.4*global.FSP;
        alarm[8]=(3.4*global.FSP)-15;
    }
}
</string>
