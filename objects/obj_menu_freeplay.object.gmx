    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if select=0
{
    if obj_input.l2
    {
        global.menu_t--
        if global.menu_t&lt;1 global.menu_t=1;
        obj_menu_bg.sprite_index=obj_menu_bg.list[global.menu_t-1];
        save_settings();
    }
    if obj_input.r2
    {
        global.menu_t++
        if global.menu_t&gt;11 global.menu_t=11;
        obj_menu_bg.sprite_index=obj_menu_bg.list[global.menu_t-1];
        save_settings();
    }
    if obj_input.l1
    {
        obj_main_menu.menu_music--
        if obj_main_menu.menu_music&lt;1 obj_main_menu.menu_music=1;
        if obj_main_menu.menu_music!=obj_main_menu.prev_music obj_main_menu.alarm[0]=1;
        
        global.bg_music=obj_main_menu.menu_music;
        save_settings();
    }
    if obj_input.r1
    {
        obj_main_menu.menu_music++
        if obj_main_menu.menu_music&gt;11 obj_main_menu.menu_music=11;
        if obj_main_menu.menu_music!=obj_main_menu.prev_music obj_main_menu.alarm[0]=1;
        
        global.bg_music=obj_main_menu.menu_music;
        save_settings();
    }
    if obj_input.upp &amp;&amp; selector&gt;0 selector--;
    if obj_input.dow &amp;&amp; selector&lt;2 selector++;
    if obj_input.a
    {
        select=1;
        audio_stop_all();
        audio_play_sound(sfx_game_start,0,false);
        global.bg_music=obj_main_menu.menu_music;
        save_game();
        global.temp_menu_t=global.menu_t;
        global.temp_bg_mus=global.bg_music;
        global.temp_stage=global.stage;
        global.temp_lives=lives;
        lives=3;
        
        global.gridw[0]=grid_w;
        global.gridh[0]=grid_h;
        global.minec[0]=grid_m;
        obj_main_menu.alarm[3]=45;
        alarm[0]=60;
    }
    if obj_input.bl
    {
        select=1;
        obj_main_menu.type=0;
        obj_main_menu.select=0;
    }
    if obj_input.rig
    {
        if selector=0 &amp;&amp; grid_w&lt;48 grid_w++;
        if selector=1 &amp;&amp; grid_h&lt;32 grid_h++;
        if selector=2 &amp;&amp; grid_m&lt;(grid_w*grid_h)-1 grid_m++;
    }
    if obj_input.lef
    {
        if selector=0 &amp;&amp; grid_w&gt;3 grid_w--;
        if selector=1 &amp;&amp; grid_h&gt;3 grid_h--;
        if selector=2 &amp;&amp; grid_m&gt;1 grid_m--;
    }
}

if select=1 &amp;&amp; obj_main_menu.type!=2 temp_x=-320 else temp_x=0;
x=lerp(x,temp_x,0.1);

temp+=0.05;
</string>
          </argument>
        </arguments>
      </action>
