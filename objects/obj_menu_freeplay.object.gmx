    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if select=0
{
    if obj_input.l2
    {
        global.menu_t--
        if global.menu_t&lt;1 global.menu_t=1;
        obj_menu_bg.sprite_index=obj_menu_bg.list[global.menu_t-1];
    }
    if obj_input.r2
    {
        global.menu_t++
        if global.menu_t&gt;10 global.menu_t=10;
        obj_menu_bg.sprite_index=obj_menu_bg.list[global.menu_t-1];
    }
    if obj_input.l1
    {
        obj_main_menu.menu_music--
        if obj_main_menu.menu_music&lt;1 obj_main_menu.menu_music=1;
        if obj_main_menu.menu_music!=obj_main_menu.prev_music obj_main_menu.alarm[0]=1;
    }
    if obj_input.r1
    {
        obj_main_menu.menu_music++
        if obj_main_menu.menu_music&gt;10 obj_main_menu.menu_music=10;
        if obj_main_menu.menu_music!=obj_main_menu.prev_music obj_main_menu.alarm[0]=1;
    }
    if obj_input.lef &amp;&amp; global.smiley_face&gt;0 global.smiley_face--;
    if obj_input.rig &amp;&amp; global.smiley_face&lt;6 global.smiley_face++;
    if obj_input.a
    {
        select=1;
        audio_stop_all();
        audio_play_sound(sfx_game_start,0,false);
        global.bg_music=obj_main_menu.menu_music;
        save_game();
        global.temp_stage=global.stage;
        global.temp_lives=lives;
        global.stage=0;
        lives=3;
        
        if grid_w&lt;3 grid_w=3;
        if grid_h&lt;3 grid_h=3;
        if grid_m&lt;1 grid_m=1;
        
        if grid_w&gt;48 grid_w=48;
        if grid_h&gt;32 grid_h=32;
        if grid_m&gt;(grid_w*grid_h)-1 grid_m=(grid_w*grid_h)-1;
        
        global.gridw[0]=grid_w;
        global.gridh[0]=grid_h;
        global.minec[0]=grid_m;
        alarm[0]=60;
    }
    if obj_input.bl
    {
        select=1;
        obj_main_menu.type=0;
        obj_main_menu.select=0;
    }
    if obj_input.c
    {
        grid_w=get_integer(global.str[91],9);
        grid_h=get_integer(global.str[92],9);
        grid_m=get_integer(global.str[93],10);
    }
}

if select=1 &amp;&amp; obj_main_menu.type!=2 temp_x=-320 else temp_x=0;
x=lerp(x,temp_x,0.1);

temp+=0.05;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_font(fnt_smoler);
draw_set_valign(fa_top);
draw_set_halign(fa_middle);
draw_text_outline(x+160,y+200,"[X] "+global.str[75],c_white,c_black,1);
draw_text_outline(x+160,y+70,"[L1/R1] "+global.str[87],c_white,c_black,1);
draw_text_outline(x+160,y+90,"[L2/R2] "+global.str[88],c_white,c_black,1);
draw_text_outline(x+160,y+120,"[&lt;-&gt;] "+global.str[89],c_white,c_black,1);
draw_text_outline(x+160,y+150,"[□] "+global.str[90],c_white,c_black,1);
draw_text_outline(x+160,y+170,"W: "+string(grid_w)+"; H: "+string(grid_h)+"; M: "+string(grid_m)+";",c_white,c_black,1);
draw_sprite_stretched(spr_ui3,0,x+136,20,48,48);

if global.route=0
{
    spr_smiley_1=spr_smiley1;
    spr_smiley_2=spr_smiley2;
    spr_smiley_3=spr_smiley3;
    spr_smiley_4=spr_smiley4;
    spr_smiley_5=spr_smiley5;
    spr_smiley_6=spr_smiley6;
    spr_smiley_86=spr_smiley86;
}
else if global.route=1
{
    spr_smiley_1=spr_murasa1;
    spr_smiley_2=spr_smiley2;
    spr_smiley_3=spr_smiley3;
    spr_smiley_4=spr_smiley4;
    spr_smiley_5=spr_smiley5;
    spr_smiley_6=spr_smiley6;
    spr_smiley_86=spr_smiley86;
}

switch global.smiley_face
{
    case 0: sprite = spr_smiley_1; temp1=0; break;
    case 1: sprite = spr_smiley_2; temp1=0; break;
    case 2: sprite = spr_smiley_3; temp1=1; break;
    case 3: sprite = spr_smiley_4; temp1=0; break;
    case 4: sprite = spr_smiley_5; temp1=2; break;
    case 5: sprite = spr_smiley_6; temp1=0; break;
    case 6: sprite = spr_smiley_86; temp1=0; break;
}

switch global.hat_type
{
    case 0: hat = -1; break;
    case 1: hat = spr_hat1; break;
    case 2: hat = spr_hat2; break;
    case 3: hat = spr_hat3; break;
    case 4: hat = spr_hat4; break;
    case 5: hat = spr_hat5; break;
    case 6: hat = spr_hat6; break;
    case 7: hat = spr_hat7; break;
}

if temp1==0 draw_sprite(sprite,0,x+160,44+the_y)
else if temp1==1 draw_sprite(sprite,0+(temp mod 2),x+160,44+the_y)
else draw_sprite(sprite,0+(temp mod 3),x+160,44+the_y);

if hat!=0
{
    draw_sprite(hat,0,x+160,44);
    the_y=2;
}
else the_y=0;
</string>
          </argument>
        </arguments>
      </action>
