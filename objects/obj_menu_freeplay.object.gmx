draw_text_outline(x+160,y+40,"[L2/R2] "+global.str[88],c_white,c_black,1);

var op1=c_white;var op2=c_white;var op3=c_white;
var oo1=c_black;var oo2=c_black;var oo3=c_black;

if selector=0{op1=c_red;oo1=c_white}
if selector=1{op2=c_red;oo2=c_white}
if selector=2{op3=c_red;oo3=c_white}

draw_text_outline(x+160,y+100,global.str[91]+": "+string(grid_w),op1,oo1,1);
draw_text_outline(x+160,y+120,global.str[92]+": "+string(grid_h),op2,oo2,1);
draw_text_outline(x+160,y+140,global.str[93]+": "+string(grid_m),op3,oo3,1);

draw_set_valign(fa_bottom);
draw_text_outline(x+160,230,"[○] - "+global.str[13],c_white,c_black,1);
</string>
