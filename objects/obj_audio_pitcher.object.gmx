        <arguments>
          <argument>
            <kind>1</kind>
            <string>temp_123=0;
show=0;
selected=1;
stop=0;
go_on=0;

if global.episode==1
{
    if global.stage==1 or global.stage==2 mus=global._music[1]
    else if global.stage==3 or global.stage==4 mus=global._music[2]
    else if global.stage==5 or global.stage==6 mus=global._music[3]
    else if global.stage==7 or global.stage==8 mus=global._music[4]
    else if global.stage==0
    {
        temp_123=global.bg_music;
        if global.bg_music&gt;6 temp_123+=2;
        mus=global._music[global.bg_music];
    }
}
else if global.episode==2
{
    if global.stage==1 or global.stage==2 mus=global._music[7]
    else if global.stage==3 or global.stage==4 mus=global._music[8]
    else if global.stage==5 or global.stage==6 mus=global._music[9]
    else if global.stage==7 or global.stage==8 mus=global._music[10]
    else if global.stage==0
    {
        temp_123=global.bg_music;
        if global.bg_music&gt;6 temp_123+=2;
        mus=global._music[global.bg_music];
    }
}

pitch=1;
alarm[0]=4*global.FSP-20;
alarm[1]=4*global.FSP;
</string>
          </argument>
        </arguments>
      </action>
    </event>
