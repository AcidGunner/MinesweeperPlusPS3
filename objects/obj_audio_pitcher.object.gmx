        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>audio_sound_pitch(mus,pitch);

if pitch&gt;0.1 pitch-=0.01;

if selected=0
{
    if obj_input.a
    {
        selected=1;
        audio_sound_pitch(mus,1);
        audio_stop_all();
        go_on=1;
        lives=3;
        audio_play_sound(sfx_1up,0,false);
        alarm[3]=3.4*global.FSP;
    }
    if obj_input.b
    {
        selected=1;
        audio_sound_pitch(mus,1);
        audio_stop_all();
        lost=1;
        audio_play_sound(sfx_gameover,0,false);
        alarm[2]=3.4*global.FSP;
    }
}
</string>
