    draw_text_outline(160,120,"X - "+global.str[95],c_blue,c_black,1);
    draw_text_outline(160,144,"O - "+global.str[96],c_red,c_black,1);
}
else
{
    if go_on=1 draw_text_outline(160,70,global.str[97],c_white,c_black,1)
    else draw_text_outline(160,70,global.str[98],c_white,c_black,1)
}
</string>
