            audio_play_sound(mus[global.stage-1],0,true);
        }
    }
    else if global.stage==10
    {
        view_xview[0]=544;
        x=704;
    }
}
else if x&gt;160 &amp;&amp; goto&lt;1 &amp;&amp; !transition
{
    if global.episode==1
    {
        if x&gt;536-152 view_xview[0]=224
        else view_xview[0]=x-160;
    }
    else if global.episode==2
    {
        if x&gt;536-152+64 view_xview[0]=224+64
