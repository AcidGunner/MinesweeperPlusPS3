{
    if x&gt;_stuff_ &amp;&amp; global.stage!=9 move=0;
    if x&gt;704 &amp;&amp; global.stage=9 move=0;
}
else if global.episode==2
{
    if x&gt;_stuff_ move=0;
}

if x&gt;536 &amp;&amp; global.episode==1
{
    if global.stage==9
    {
        if goto=0 view_xview[0]=lerp(view_xview[0],544,0.02);
