  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>select=1;
temp_y=y;
type=0;
option=0;
option_1_max=0;
option_1=c_white;
option_2=c_white;
option_3=c_white;

option_1_list[0]=global.str[81];
if global.unlocked
{
    option_1_list[1]=global.str[82];
    option_1_max=1;
}

option_2_list[0]=global.str[83];
option_2_list[1]=global.str[84];

option_3_list[0]=global.str[85];
option_3_list[1]=global.str[86];
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if select=0
{
    if obj_input.bl
    {
        select=1;
        obj_menu_adventure.type=0;
        obj_menu_adventure.select=0;
    }
    if obj_input.upp &amp;&amp; option&gt;0 option--;
    if obj_input.dow &amp;&amp; option&lt;2 option++;
    if obj_input.lef
    {
        if option=0 &amp;&amp; global.route&gt;0 global.route--;
        if option=1 &amp;&amp; global.episode&gt;1 global.episode--;
        if option=2 &amp;&amp; global.gamemode&gt;0 global.gamemode--;
    }
    if obj_input.rig
    {
        if option=0 &amp;&amp; global.route&lt;option_1_max global.route++;
        if option=1 &amp;&amp; global.episode&lt;2 global.episode++;
        if option=2 &amp;&amp; global.gamemode&lt;1 global.gamemode++;
    }
}

switch option
{
    case 0: option_1=c_red; option_2=c_white; option_3=c_white; break;
    case 1: option_1=c_white; option_2=c_red; option_3=c_white; break;
    case 2: option_1=c_white; option_2=c_white; option_3=c_red; break;
}

if select=1 temp_y=-240; else temp_y=0;
x=obj_menu_adventure.x;
y=lerp(y,temp_y,0.1);
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_font(fnt_smoler);
draw_set_halign(fa_middle);
draw_set_valign(fa_top);
draw_text_outline(x+160,y+2,global.str[77],c_white,c_black,1);

draw_text_outline(x+160,y+40,global.str[78]+":#"+option_1_list[global.route],option_1,c_black,1);
draw_text_outline(x+160,y+100,global.str[79]+":#"+option_2_list[global.episode-1],option_2,c_black,1);
draw_text_outline(x+160,y+160,global.str[80]+":#"+option_3_list[global.gamemode],option_3,c_black,1);
draw_text_outline(x+160,y+220,"[○] "+global.str[13],c_white,c_black,1);
</string>
          </argument>
        </arguments>
      </action>
    </event>
