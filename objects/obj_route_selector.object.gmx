        <arguments>
          <argument>
            <kind>1</kind>
            <string>display_set_gui_size(640,480);

draw_set_color(c_gray);
draw_rectangle(50,50,590,430,false);

if obj_input.upp &amp;&amp; select&gt;0 select--;
if obj_input.dow &amp;&amp; select&lt;2 select++;

draw_set_halign(fa_center);
draw_set_font(fnt_main);
draw_set_valign(fa_top);
draw_set_color(c_red);
draw_text(320,60,"Route Selector");
draw_set_color(c_white);
draw_set_valign(fa_bottom);
draw_text(320,420,"START - CONFIRM");
draw_set_valign(fa_middle);

var _i = 2;
var i_ = _i/2;

for (var i = 0; i &lt;= _i; i++)
{
    draw_text(320,240+(i-i_)*40,obj_main_menu.route_list[i]);
}

draw_text(320,240+(select-i_)*40,"&gt;                          &lt;");

if obj_input.start
{
    if !(!global.unlocked &amp;&amp; select=1)
    {
        global.route=select;
        obj_menu_adventure_settings.alarm[0]=1;
    }
    obj_menu_adventure.s3lect=0;
    instance_destroy();
}

display_set_gui_size(320,240);
</string>
          </argument>
        </arguments>
      </action>
